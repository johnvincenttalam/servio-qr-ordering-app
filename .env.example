# Supabase project — fill these in via .env.local (gitignored).
# Get them from Project Settings → API in the Supabase dashboard.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Web Push public key (PUBLIC half of a VAPID keypair). Generate with:
#   npx web-push generate-vapid-keys
# The matching PRIVATE key goes into the Supabase Edge Function secret
# (VAPID_PRIVATE_KEY) — never include it here or in .env.local.
VITE_VAPID_PUBLIC_KEY=

# Sentry DSN — leave blank to disable error monitoring. Get one from
# sentry.io → Project Settings → Client Keys (DSN). Source map upload
# requires SENTRY_AUTH_TOKEN at build time (not added yet).
VITE_SENTRY_DSN=
